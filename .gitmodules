	path = lib/tree-sitter-c
	url = https://github.com/tree-sitter/tree-sitter-c.git
[submodule "lib/tree-sitter-asm"]
	path = lib/tree-sitter-asm
	url = https://github.com/RubixDev/tree-sitter-asm.git
[submodule "lib/tree-sitter-cpp"]
	path = lib/tree-sitter-cpp
	url = https://github.com/tree-sitter/tree-sitter-cpp.git
